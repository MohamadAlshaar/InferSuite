# ─── Deployment target ──────────────────────────────────────────────────────
# Options: eks | minikube
DEPLOY_ENV=eks

# ─── AWS (EKS only) ─────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID
AWS_REGION=YOUR_REGION
COMPUTE_INSTANCE_TYPE=m7i.2xlarge
GPU_INSTANCE_TYPE=p5.4xlarge

# ─── Kubernetes namespaces ───────────────────────────────────────────────────
NAMESPACE_SERVICE=llm-service
NAMESPACE_LLMD=llm-d

# ─── Model ──────────────────────────────────────────────────────────────────
# Change MODEL_NAME + MODEL_HF_REPO together when switching models.
# MODEL_MAX_LEN: set to the model's max context (14b=32768, 32b=32768, 0.5b=2048)
# MODEL_STORAGE_GI: EBS volume size for model weights (14b≈30Gi, 32b≈70Gi)
# MODEL_REPLICAS: number of vLLM decode workers (each needs one GPU node)
MODEL_NAME=qwen2.5-14b
MODEL_HF_REPO=Qwen/Qwen2.5-14B-Instruct
MODEL_MAX_LEN=32768
MODEL_GPU_MEM_UTIL=0.90
MODEL_STORAGE_GI=40
MODEL_REPLICAS=1
