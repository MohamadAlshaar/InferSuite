            +from sympy import S, Symbol, simplify, diff, N, sqrt, pi, Rational 
            +from sympy.stats import *                                          
            +from sympy.stats.crv_types import (                                
            +    ArcsinDistribution, DagumDistribution, FrechetDistribution,    
            +    GammaDistribution, GammaInverseDistribution,                   
            KumaraswamyDistribution,                                            
            +    LaplaceDistribution, LogisticDistribution,                     
            NakagamiDistribution,                                               
            +    StudentTDistribution, UniformSumDistribution)                  
            +                                                                   
            +x = Symbol('x', real=True)                                         
            +                                                                   
            +                                                                   
            +def check(name, dist, test_points):                                
            +    """Differentiate the _cdf and compare with pdf numerically.""" 
            +    print("=== %s ===" % name)                                     
            +    cdf_expr = dist._cdf(x)                                        
            +    pdf_expr = dist.pdf(x)                                         
            +    dcdf = diff(cdf_expr, x)                                       
            +    print("cdf:", cdf_expr)                                        
            +    print("dcdf:", simplify(dcdf))                                 
            +    for pt in test_points:                                         
            +        try:                                                       
            +            c = N(cdf_expr.subs(x, pt))                            
            +            p_cdf = N(dcdf.subs(x, pt))                            
            +            p_pdf = N(pdf_expr.subs(x, pt))                        
            +            print("  x=%s: cdf=%s, diff(cdf)=%s, pdf=%s, match=%s" 
            % (                                                                 
            +                pt, c, p_cdf, p_pdf, abs(p_cdf - p_pdf) < 1e-8))   
            +        except Exception as e:                                     
            +            print("  x=%s: EXCEPTION %r" % (pt, e))                
            +    print()                                                        
            +                                                                   
            +                                                                   
            +check("Arcsin", ArcsinDistribution(0, 3), [0.5, 1.0, 1.5, 2.5])    
            +check("Dagum", DagumDistribution(S(1)/3, S(1)/5, 2), [0.5, 1.0,    
            3.0, 5.0])                                                          
            +check("Frechet", FrechetDistribution(S(4)/3, 1, 2), [3.0, 5.0,     
            10.0])                                                              
            +check("Gamma", GammaDistribution(S(1)/10, 2), [0.5, 1.0, 3.0, 5.0])
            +check("GammaInverse", GammaInverseDistribution(S(5)/7, 2), [0.5,   
            1.0, 3.0, 5.0])                                                     
            +check("Kumaraswamy", KumaraswamyDistribution(S(1)/123, 5), [0.1,   
            0.3, 0.5, 0.9])                                                     
            +check("Laplace", LaplaceDistribution(2, 3), [0.0, 1.0, 2.0, 5.0,   
            10.0])                                                              
            +check("Logistic", LogisticDistribution(1, S(1)/10), [0.5, 1.0, 1.5,
            2.0])                                                               
            +check("Nakagami", NakagamiDistribution(S(7)/3, 1), [0.5, 1.0, 2.0, 
            3.0])                                                               
            +check("StudentT", StudentTDistribution(10), [-2.0, -1.0, 0.0, 1.0, 
            2.0])                                                               
            +check("UniformSum", UniformSumDistribution(5), [0.5, 1.0, 2.0, 3.0,
            4.5])                                                               
