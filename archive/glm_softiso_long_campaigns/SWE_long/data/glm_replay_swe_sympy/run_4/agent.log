               723  # Erlang distribution                                       
            ----------------------------------------------------------          
               724                                                              
               725  def Erlang(name, k, l):                                     
               726      r"""                                                    
               727      Create a continuous random variable with an Erlang      
            distribution.                                                       
               728                                                              
               729      The density of the Erlang distribution is given by      
               730                                                              
               731      .. math::                                               
               732          f(x) := \frac{\lambda^k x^{k-1} e^{-\lambda         
            x}}{(k-1)!}                                                         
               733                                                              
               734      with :math:`x \in [0,\infty]`.                          
               735                                                              
               736      Parameters                                              
               737      ==========                                              
               738                                                              
               739      k : Integer                                             
               740      l : Real number, `\lambda > 0`, the rate                
               741                                                              
               742      Returns                                                 
               743      =======                                                 
               744                                                              
               745      A RandomSymbol.                                         
               746                                                              
               747      Examples                                                
               748      ========                                                
               749                                                              
               750      >>> from sympy.stats import Erlang, density, cdf, E,    
            variance                                                            
               751      >>> from sympy import Symbol, simplify, pprint          
               752                                                              
               753      >>> k = Symbol("k", integer=True, positive=True)        
               754      >>> l = Symbol("l", positive=True)                      
               755      >>> z = Symbol("z")                                     
               756                                                              
               757      >>> X = Erlang("x", k, l)                               
               758                                                              
               759      >>> D = density(X)(z)                                   
               760      >>> pprint(D, use_unicode=False)                        
               761       k  k - 1  -l*z                                         
               762      l *z     *e                                             
               763      ---------------                                         
               764          gamma(k)                                            
               765                                                              
               766      >>> C = cdf(X, meijerg=True)(z)                         
               767      >>> pprint(C, use_unicode=False)                        
               768      /   -2*I*pi*k                                           
               769      |k*e         *lowergamma(k, l*z)                        
               770      |-------------------------------  for z >= 0            
               771      <          gamma(k + 1)                                 
               772      |                                                       
               773      |               0                 otherwise             
               774      \                                                       
               775                                                              
               776      >>> simplify(E(X))                                      
               777      k/l                                                     
               778                                                              
               779      >>> simplify(variance(X))                               
               780      k/l**2                                                  
               781                                                              
               782      References                                              
               783      ==========                                              
               784                                                              
               785      .. [1] http://en.wikipedia.org/wiki/Erlang_distribution 
               786      .. [2]                                                  
            http://mathworld.wolfram.com/ErlangDistribution.html                
               787      """                                                     
               788                                                              
               789      return rv(name, GammaDistribution, (k, 1/l))            
