              2477                                                              
              2478      def sample(self):                                       
              2479          return random.uniform(self.left, self.right)        
              2480                                                              
              2481                                                              
              2482  def Uniform(name, left, right):                             
              2483      r"""                                                    
              2484      Create a continuous random variable with a uniform      
            distribution.                                                       
              2485                                                              
              2486      The density of the uniform distribution is given by     
              2487                                                              
              2488      .. math::                                               
              2489          f(x) := \begin{cases}                               
              2490                    \frac{1}{b - a} & \text{for } x \in [a,b] 
            \\                                                                  
              2491                    0               & \text{otherwise}        
              2492                  \end{cases}                                 
              2493                                                              
              2494      with :math:`x \in [a,b]`.                               
              2495                                                              
              2496      Parameters                                              
              2497      ==========                                              
              2498                                                              
              2499      a : Real number, :math:`-\infty < a` the left boundary  
              2500      b : Real number, :math:`a < b < \infty` the right       
            boundary                                                            
              2501                                                              
              2502      Returns                                                 
              2503      =======                                                 
              2504                                                              
              2505      A RandomSymbol.                                         
              2506                                                              
              2507      Examples                                                
              2508      ========                                                
              2509                                                              
              2510      >>> from sympy.stats import Uniform, density, cdf, E,   
            variance, skewness                                                  
              2511      >>> from sympy import Symbol, simplify                  
              2512                                                              
              2513      >>> a = Symbol("a", negative=True)                      
              2514      >>> b = Symbol("b", positive=True)                      
              2515      >>> z = Symbol("z")                                     
              2516                                                              
              2517      >>> X = Uniform("x", a, b)                              
              2518                                                              
              2519      >>> density(X)(z)                                       
              2520      Piecewise((1/(-a + b), (b >= z) & (a <= z)), (0, True)) 
              2521                                                              
              2522      >>> cdf(X)(z)  # doctest: +SKIP                         
              2523      -a/(-a + b) + z/(-a + b)                                
              2524                                                              
              2525      >>> simplify(E(X))                                      
              2526      a/2 + b/2                                               
              2527                                                              
              2528      >>> simplify(variance(X))                               
              2529      a**2/12 - a*b/6 + b**2/12                               
              2530                                                              
              2531      References                                              
              2532      ==========                                              
              2533                                                              
              2534      .. [1]                                                  
            http://en.wikipedia.org/wiki/Uniform_distribution_%28continuous%29  
              2535      .. [2]                                                  
            http://mathworld.wolfram.com/UniformDistribution.html               
              2536      """                                                     
              2537                                                              
              2538      return rv(name, UniformDistribution, (left, right))     
              2539                                                              
              2540                                                              
            #-------------------------------------------------------------------
            ------------                                                        
              2541  # UniformSum distribution                                   
            ------------------------------------------------------              
              2542                                                              
              2543                                                              
              2544  class UniformSumDistribution(SingleContinuousDistribution): 
              2545      _argnames = ('n',)                                      
              2546                                                              
              2547      @property                                               
              2548      def set(self):                                          
              2549          return Interval(0, self.n)                          
              2550                                                              
              2551      def pdf(self, x):                                       
              2552          n = self.n                                          
              2553          k = Dummy("k")                                      
              2554          return 1/factorial(                                 
              2555              n - 1)*Sum((-1)**k*binomial(n, k)*(x - k)**(n - 
            1), (k, 0, floor(x)))                                               
              2556                                                              
              2557                                                              
              2558                                                              
              2559  def UniformSum(name, n):                                    
              2560      r"""                                                    
              2561      Create a continuous random variable with an Irwin-Hall  
            distribution.                                                       
              2562                                                              
              2563      The probability distribution function depends on a      
            single parameter                                                    
              2564      `n` which is an integer.                                
              2565                                                              
              2566      The density of the Irwin-Hall distribution is given by  
              2567                                                              
              2568      .. math ::                                              
              2569          f(x) := \frac{1}{(n-1)!}\sum_{k=0}^{\lfloor         
            x\rfloor}(-1)^k                                                     
              2570                  \binom{n}{k}(x-k)^{n-1}                     
              2571                                                              
              2572      Parameters                                              
              2573      ==========                                              
              2574                                                              
              2575      n : A positive Integer, `n > 0`                         
              2576                                                              
              2577      Returns                                                 
              2578      =======                                                 
              2579                                                              
              2580      A RandomSymbol.                                         
              2581                                                              
              2582      Examples                                                
              2583      ========                                                
              2584                                                              
              2585      >>> from sympy.stats import UniformSum, density         
              2586      >>> from sympy import Symbol, pprint                    
              2587                                                              
              2588      >>> n = Symbol("n", integer=True)                       
              2589      >>> z = Symbol("z")                                     
              2590                                                              
              2591      >>> X = UniformSum("x", n)                              
              2592                                                              
              2593      >>> D = density(X)(z)                                   
              2594      >>> pprint(D, use_unicode=False)                        
              2595      floor(z)                                                
              2596        ___                                                   
              2597        \  `                                                  
              2598         \         k         n - 1 /n\                        
              2599          )    (-1) *(-k + z)     *| |                        
              2600         /                         \k/                        
              2601        /__,                                                  
              2602       k = 0                                                  
              2603      --------------------------------                        
              2604                  (n - 1)!                                    
              2605                                                              
              2606      References                                              
              2607      ==========                                              
              2608                                                              
              2609      .. [1]                                                  
            http://en.wikipedia.org/wiki/Uniform_sum_distribution               
              2610      .. [2]                                                  
            http://mathworld.wolfram.com/UniformSumDistribution.html            
              2611      """                                                     
              2612                                                              
              2613      return rv(name, UniformSumDistribution, (n, ))          
              2614                                                              
              2615                                                              
            #-------------------------------------------------------------------
            ------------                                                        
              2616  # VonMises distribution                                     
            --------------------------------------------------------            
              2617                                                              
              2618                                                              
              2619  class VonMisesDistribution(SingleContinuousDistribution):   
              2620      _argnames = ('mu', 'k')                                 
                                                                                
                                                                                
