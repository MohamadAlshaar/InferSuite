            +                                                                   
            +x = Symbol('x', real=True)                                         
            +                                                                   
            +                                                                   
            +def check(name, dist, test_points):                                
            +    """Differentiate the _cdf and compare with pdf numerically.""" 
            +    print("=== %s ===" % name)                                     
            +    cdf_expr = dist._cdf(x)                                        
            +    pdf_expr = dist.pdf(x)                                         
            +    dcdf = diff(cdf_expr, x)                                       
            +    print("cdf:", cdf_expr)                                        
            +    print("dcdf:", simplify(dcdf))                                 
            +    for pt in test_points:                                         
            +        try:                                                       
            +            c = N(cdf_expr.subs(x, pt))                            
            +            p_cdf = N(dcdf.subs(x, pt))                            
            +            p_pdf = N(pdf_expr.subs(x, pt))                        
            +            print("  x=%s: cdf=%s, diff(cdf)=%s, pdf=%s, match=%s" 
            % (                                                                 
            +                pt, c, p_cdf, p_pdf, abs(p_cdf - p_pdf) < 1e-8))   
