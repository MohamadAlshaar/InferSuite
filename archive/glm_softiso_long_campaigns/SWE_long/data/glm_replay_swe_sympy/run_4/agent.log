            sympy import S, Symbol, simplify, diff, N, sqrt, pi, Rational,      
            floor, Sum, binomial, factorial                                     
            from sympy.stats.crv_types import UniformSumDistribution            
                                                                                
            x = Symbol('"'"'x'"'"', real=True)                                  
                                                                                
            dist = UniformSumDistribution(5)                                    
            cdf_expr = dist._cdf(x)                                             
            pdf_expr = dist.pdf(x)                                              
                                                                                
            # Numerically check that the derivative of the cdf (as a finite     
            difference) matches pdf                                             
            import random                                                       
            random.seed(0)                                                      
            h = 1e-7                                                            
            ok = True                                                           
            for _ in range(20):                                                 
                pt = random.uniform(0.01, 4.99)                                 
                # avoid points near integers where floor changes                
                if abs(pt - round(pt)) < 0.05:                                  
                    continue                                                    
                c_plus = N(cdf_expr.subs(x, pt + h))                            
                c_minus = N(cdf_expr.subs(x, pt - h))                           
                dcdf = (c_plus - c_minus) / (2*h)                               
                p_pdf = N(pdf_expr.subs(x, pt))                                 
                print("pt=%s dcdf=%s pdf=%s diff=%s" % (pt, dcdf, p_pdf,        
            abs(dcdf - p_pdf)))                                                 
                if abs(dcdf - p_pdf) > 1e-5:                                    
                    ok = False                                                  
            print("OK" if ok else "FAIL")                                       
            '                                                                   
