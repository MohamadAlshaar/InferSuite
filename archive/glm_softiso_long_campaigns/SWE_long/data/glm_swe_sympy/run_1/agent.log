              2385                                                              
              2386      .. math::                                               
              2387          f(x) := \begin{cases}                               
              2388                    0 & \mathrm{for\ } x < a, \\              
              2389                    \frac{2(x-a)}{(b-a)(c-a)} & \mathrm{for\ }
            a \le x < c, \\                                                     
              2390                    \frac{2}{b-a} & \mathrm{for\ } x = c, \\  
              2391                    \frac{2(b-x)}{(b-a)(b-c)} & \mathrm{for\ }
            c < x \le b, \\                                                     
              2392                    0 & \mathrm{for\ } b < x.                 
              2393                  \end{cases}                                 
              2394                                                              
              2395      Parameters                                              
              2396      ==========                                              
              2397                                                              
              2398      a : Real number, :math:`a \in \left(-\infty,            
            \infty\right)`                                                      
              2399      b : Real number, :math:`a < b`                          
              2400      c : Real number, :math:`a \leq c \leq b`                
              2401                                                              
              2402      Returns                                                 
              2403      =======                                                 
              2404                                                              
              2405      A RandomSymbol.                                         
              2406                                                              
              2407      Examples                                                
              2408      ========                                                
              2409                                                              
              2410      >>> from sympy.stats import Triangular, density, E      
              2411      >>> from sympy import Symbol, pprint                    
              2412                                                              
              2413      >>> a = Symbol("a")                                     
              2414      >>> b = Symbol("b")                                     
              2415      >>> c = Symbol("c")                                     
              2416      >>> z = Symbol("z")                                     
              2417                                                              
              2418      >>> X = Triangular("x", a,b,c)                          
              2419                                                              
              2420      >>> pprint(density(X)(z), use_unicode=False)            
              2421      /    -2*a + 2*z                                         
              2422      |-----------------  for And(a <= z, c > z)              
              2423      |(-a + b)*(-a + c)                                      
              2424      |                                                       
              2425      |       2                                               
              2426      |     ------              for c = z                     
              2427      <     -a + b                                            
              2428      |                                                       
              2429      |   2*b - 2*z                                           
              2430      |----------------   for And(b >= z, c < z)              
              2431      |(-a + b)*(b - c)                                       
              2432      |                                                       
              2433      \        0                otherwise                     
              2434                                                              
              2435      References                                              
              2436      ==========                                              
              2437                                                              
              2438      .. [1]                                                  
            http://en.wikipedia.org/wiki/Triangular_distribution                
              2439      .. [2]                                                  
            http://mathworld.wolfram.com/TriangularDistribution.html            
              2440      """                                                     
              2441                                                              
              2442      return rv(name, TriangularDistribution, (a, b, c))      
              2443                                                              
              2444                                                              
            #-------------------------------------------------------------------
            ------------                                                        
              2445  # Uniform distribution                                      
            ---------------------------------------------------------           
              2446                                                              
              2447                                                              
              2448  class UniformDistribution(SingleContinuousDistribution):    
              2449      _argnames = ('left', 'right')                           
              2450                                                              
              2451      def pdf(self, x):                                       
              2452          left, right = self.left, self.right                 
              2453          return Piecewise(                                   
              2454              (S.One/(right - left), And(left <= x, x <=      
            right)),                                                            
              2455              (S.Zero, True)                                  
              2456          )                                                   
              2457                                                              
              2458      def _cdf(self, x):                                      
              2459          left, right = self.left, self.right                 
              2460          return Piecewise(                                   
              2461              (S.Zero, x < left),                             
              2462              ((x - left)/(right - left), x <= right),        
              2463              (S.One, True)                                   
              2464          )                                                   
              2465                                                              
              2466      def _characteristic_function(self, t):                  
              2467          left, right = self.left, self.right                 
              2468          return (exp(I*t*right) - exp(I*t*left)) /           
            (I*t*(right - left))                                                
              2469                                                              
              2470      def expectation(self, expr, var, **kwargs):             
              2471          from sympy import Max, Min                          
              2472          kwargs['evaluate'] = True                           
              2473          result =                                            
            SingleContinuousDistribution.expectation(self, expr, var, **kwargs) 
              2474          result = result.subs({Max(self.left, self.right):   
            self.right,                                                         
              2475                                Min(self.left, self.right):   
            self.left})                                                         
              2476          return result                                       
              2477                                                              
              2478      def sample(self):                                       
              2479          return random.uniform(self.left, self.right)        
              2480                                                              
              2481                                                              
              2482  def Uniform(name, left, right):                             
              2483      r"""                                                    
              2484      Create a continuous random variable with a uniform      
            distribution.                                                       
              2485                                                              
              2486      The density of the uniform distribution is given by     
              2487                                                              
              2488      .. math::                                               
              2489          f(x) := \begin{cases}                               
              2490                    \frac{1}{b - a} & \text{for } x \in [a,b] 
            \\                                                                  
              2491                    0               & \text{otherwise}        
              2492                  \end{cases}                                 
              2493                                                              
              2494      with :math:`x \in [a,b]`.                               
              2495                                                              
              2496      Parameters                                              
              2497      ==========                                              
              2498                                                              
              2499      a : Real number, :math:`-\infty < a` the left boundary  
              2500      b : Real number, :math:`a < b < \infty` the right       
            boundary                                                            
              2501                                                              
              2502      Returns                                                 
              2503      =======                                                 
              2504                                                              
              2505      A RandomSymbol.                                         
              2506                                                              
              2507      Examples                                                
              2508      ========                                                
              2509                                                              
              2510      >>> from sympy.stats import Uniform, density, cdf, E,   
            variance, skewness                                                  
              2511      >>> from sympy import Symbol, simplify                  
              2512                                                              
              2513      >>> a = Symbol("a", negative=True)                      
              2514      >>> b = Symbol("b", positive=True)                      
              2515      >>> z = Symbol("z")                                     
              2516                                                              
              2517      >>> X = Uniform("x", a, b)                              
              2518                                                              
              2519      >>> density(X)(z)                                       
              2520      Piecewise((1/(-a + b), (b >= z) & (a <= z)), (0, True)) 
              2521                                                              
              2522      >>> cdf(X)(z)  # doctest: +SKIP                         
              2523      -a/(-a + b) + z/(-a + b)                                
              2524                                                              
              2525      >>> simplify(E(X))                                      
              2526      a/2 + b/2                                               
              2527                                                              
              2528      >>> simplify(variance(X))                               
              2529      a**2/12 - a*b/6 + b**2/12                               
              2530                                                              
              2531      References                                              
              2532      ==========                                              
              2533                                                              
              2534      .. [1]                                                  
            http://en.wikipedia.org/wiki/Uniform_distribution_%28continuous%29  
              2535      .. [2]                                                  
            http://mathworld.wolfram.com/UniformDistribution.html               
              2536      """                                                     
              2537                                                              
              2538      return rv(name, UniformDistribution, (left, right))     
              2539                                                              
              2540                                                              
            #-------------------------------------------------------------------
            ------------                                                        
              2541  # UniformSum distribution                                   
            ------------------------------------------------------              
              2542                                                              
              2543                                                              
              2544  class UniformSumDistribution(SingleContinuousDistribution): 
              2545      _argnames = ('n',)                                      
              2546                                                              
              2547      @property                                               
              2548      def set(self):                                          
              2549          return Interval(0, self.n)                          
              2550                                                              
              2551      def pdf(self, x):                                       
              2552          n = self.n                                          
              2553          k = Dummy("k")                                      
              2554          return 1/factorial(                                 
              2555              n - 1)*Sum((-1)**k*binomial(n, k)*(x - k)**(n - 
            1), (k, 0, floor(x)))                                               
              2556                                                              
              2557                                                              
              2558                                                              
              2559  def UniformSum(name, n):                                    
              2560      r"""                                                    
              2561      Create a continuous random variable with an Irwin-Hall  
            distribution.                                                       
              2562                                                              
              2563      The probability distribution function depends on a      
            single parameter                                                    
              2564      `n` which is an integer.                                
              2565                                                              
              2566      The density of the Irwin-Hall distribution is given by  
              2567                                                              
              2568      .. math ::                                              
              2569          f(x) := \frac{1}{(n-1)!}\sum_{k=0}^{\lfloor         
            x\rfloor}(-1)^k                                                     
              2570                  \binom{n}{k}(x-k)^{n-1}                     
              2571                                                              
              2572      Parameters                                              
              2573      ==========                                              
              2574                                                              
              2575      n : A positive Integer, `n > 0`                         
              2576                                                              
              2577      Returns                                                 
              2578      =======                                                 
              2579                                                              
              2580      A RandomSymbol.                                         
              2581                                                              
              2582      Examples                                                
              2583      ========                                                
              2584                                                              
              2585      >>> from sympy.stats import UniformSum, density         
              2586      >>> from sympy import Symbol, pprint                    
              2587                                                              
              2588      >>> n = Symbol("n", integer=True)                       
              2589      >>> z = Symbol("z")                                     
              2590                                                              
              2591      >>> X = UniformSum("x", n)                              
              2592                                                              
              2593      >>> D = density(X)(z)                                   
              2594      >>> pprint(D, use_unicode=False)                        
              2595      floor(z)                                                
              2596        ___                                                   
              2597        \  `                                                  
              2598         \         k         n - 1 /n\                        
              2599          )    (-1) *(-k + z)     *| |                        
              2600         /                         \k/                        
              2601        /__,                                                  
              2602       k = 0                                                  
              2603      --------------------------------                        
              2604                  (n - 1)!                                    
              2605                                                              
              2606      References                                              
              2607      ==========                                              
              2608                                                              
              2609      .. [1]                                                  
            http://en.wikipedia.org/wiki/Uniform_sum_distribution               
              2610      .. [2]                                                  
            http://mathworld.wolfram.com/UniformSumDistribution.html            
              2611      """                                                     
              2612                                                              
              2613      return rv(name, UniformSumDistribution, (n, ))          
              2614                                                              
              2615                                                              
