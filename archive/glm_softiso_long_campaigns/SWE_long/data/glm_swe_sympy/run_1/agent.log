            #-------------------------------------------------------------------
            ------------                                                        
               663  # Dagum distribution                                        
            -----------------------------------------------------------         
               664                                                              
               665                                                              
               666  class DagumDistribution(SingleContinuousDistribution):      
               667      _argnames = ('p', 'a', 'b')                             
               668                                                              
               669      def pdf(self, x):                                       
               670          p, a, b = self.p, self.a, self.b                    
               671          return a*p/x*((x/b)**(a*p)/(((x/b)**a + 1)**(p +    
            1)))                                                                
               672                                                              
               673                                                              
               674  def Dagum(name, p, a, b):                                   
               675      r"""                                                    
               676      Create a continuous random variable with a Dagum        
            distribution.                                                       
               677                                                              
               678      The density of the Dagum distribution is given by       
               679                                                              
               680      .. math::                                               
               681          f(x) := \frac{a p}{x} \left(                        
            \frac{\left(\tfrac{x}{b}\right)^{a p}}                              
               682                  {\left(\left(\tfrac{x}{b}\right)^a + 1      
            \right)^{p+1}} \right)                                              
               683                                                              
               684      with :math:`x > 0`.                                     
               685                                                              
               686      Parameters                                              
               687      ==========                                              
               688                                                              
               689      p : Real number, `p > 0`, a shape                       
               690      a : Real number, `a > 0`, a shape                       
               691      b : Real number, `b > 0`, a scale                       
               692                                                              
               693      Returns                                                 
               694      =======                                                 
               695                                                              
               696      A RandomSymbol.                                         
               697                                                              
               698      Examples                                                
               699      ========                                                
               700                                                              
               701      >>> from sympy.stats import Dagum, density              
               702      >>> from sympy import Symbol, simplify                  
               703                                                              
               704      >>> p = Symbol("p", positive=True)                      
               705      >>> b = Symbol("b", positive=True)                      
               706      >>> a = Symbol("a", positive=True)                      
               707      >>> z = Symbol("z")                                     
               708                                                              
               709      >>> X = Dagum("x", p, a, b)                             
               710                                                              
               711      >>> density(X)(z)                                       
               712      a*p*(z/b)**(a*p)*((z/b)**a + 1)**(-p - 1)/z             
               713                                                              
               714      References                                              
               715      ==========                                              
               716                                                              
               717      .. [1] http://en.wikipedia.org/wiki/Dagum_distribution  
               718      """                                                     
               719                                                              
               720      return rv(name, DagumDistribution, (p, a, b))           
               721                                                              
               722                                                              
            #-------------------------------------------------------------------
            ------------                                                        
               723  # Erlang distribution                                       
            ----------------------------------------------------------          
               724                                                              
               725  def Erlang(name, k, l):                                     
               726      r"""                                                    
               727      Create a continuous random variable with an Erlang      
            distribution.                                                       
               728                                                              
               729      The density of the Erlang distribution is given by      
               730                                                              
               731      .. math::                                               
               732          f(x) := \frac{\lambda^k x^{k-1} e^{-\lambda         
            x}}{(k-1)!}                                                         
               733                                                              
               734      with :math:`x \in [0,\infty]`.                          
               735                                                              
               736      Parameters                                              
               737      ==========                                              
               738                                                              
               739      k : Integer                                             
               740      l : Real number, `\lambda > 0`, the rate                
               741                                                              
               742      Returns                                                 
               743      =======                                                 
               744                                                              
               745      A RandomSymbol.                                         
               746                                                              
               747      Examples                                                
               748      ========                                                
               749                                                              
               750      >>> from sympy.stats import Erlang, density, cdf, E,    
            variance                                                            
               751      >>> from sympy import Symbol, simplify, pprint          
               752                                                              
               753      >>> k = Symbol("k", integer=True, positive=True)        
               754      >>> l = Symbol("l", positive=True)                      
               755      >>> z = Symbol("z")                                     
               756                                                              
               757      >>> X = Erlang("x", k, l)                               
               758                                                              
               759      >>> D = density(X)(z)                                   
               760      >>> pprint(D, use_unicode=False)                        
               761       k  k - 1  -l*z                                         
               762      l *z     *e                                             
               763      ---------------                                         
               764          gamma(k)                                            
               765                                                              
               766      >>> C = cdf(X, meijerg=True)(z)                         
               767      >>> pprint(C, use_unicode=False)                        
               768      /   -2*I*pi*k                                           
               769      |k*e         *lowergamma(k, l*z)                        
               770      |-------------------------------  for z >= 0            
               771      <          gamma(k + 1)                                 
               772      |                                                       
               773      |               0                 otherwise             
               774      \                                                       
               775                                                              
               776      >>> simplify(E(X))                                      
               777      k/l                                                     
               778                                                              
               779      >>> simplify(variance(X))                               
               780      k/l**2                                                  
               781                                                              
               782      References                                              
               783      ==========                                              
               784                                                              
               785      .. [1] http://en.wikipedia.org/wiki/Erlang_distribution 
               786      .. [2]                                                  
            http://mathworld.wolfram.com/ErlangDistribution.html                
               787      """                                                     
