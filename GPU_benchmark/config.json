{
  "_comment": "GPU sweep configuration. Endpoints can be overridden by env vars (see README). Talks DIRECTLY to vLLM (OpenAI-compatible) — no FastAPI orchestrator, no RAG, no cache.",

  "model": "qwen2.5-14b",
  "vllm_base_url": "http://ms-decode-direct.llm-d.svc.cluster.local:8000",
  "vllm_metrics_url": "http://ms-decode-direct.llm-d.svc.cluster.local:8000/metrics",
  "dcgm_metrics_url": "",

  "request_timeout_s": 600,
  "discard_first": true,
  "scrape_interval_s": 0.1,

  "prefill_sweep": {
    "input_tokens": [128, 256, 512, 1024, 2048, 4096, 8192],
    "output_tokens": 1,
    "n": 5,
    "warmup": { "input_tokens": 512, "output_tokens": 1, "n": 5 }
  },

  "decode_sweep": {
    "input_tokens": 1,
    "output_tokens": [64, 128, 256, 512, 1024],
    "n": 5,
    "warmup": { "input_tokens": 1, "output_tokens": 512, "n": 3 }
  }
}
