# -----------------------------------------------------------------------------
# App bind
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8080

# -----------------------------------------------------------------------------
# Model serving backend
# -----------------------------------------------------------------------------
MODEL_BACKEND=llmd
VLLM_BASE_URL=http://127.0.0.1:8001

LLMD_BASE_URL=http://127.0.0.1:8000
LLMD_API_MODE=completions
LLMD_CHAT_PATH=/v1/chat/completions
LLMD_COMPLETIONS_PATH=/v1/completions
MODEL_SERVER_TIMEOUT_S=300.0

SERVED_MODEL_NAME=qwen2.5-0.5b
CACHE_SCOPE=local-dev

# -----------------------------------------------------------------------------
# Exact cache
# -----------------------------------------------------------------------------
EXACT_CACHE_ENABLED=0
VALKEY_URL=redis://127.0.0.1:6379/0
EXACT_CACHE_TTL_SEC=3600

# -----------------------------------------------------------------------------
# Semantic cache (Milvus + MongoDB)
# -----------------------------------------------------------------------------
SEM_CACHE_ENABLED=1
SEM_CACHE_THRESHOLD=0.88
SEM_CACHE_TTL_SEC=86400

# Default: uses BGE (same model as RAG — one fewer model to download/load)
SEM_CACHE_EMBED_MODEL=BAAI/bge-base-en-v1.5
SEM_CACHE_EMBED_MODEL_PATH=/path/to/bge-base-en-v1.5
# Optional: use MiniLM instead (384-dim, lighter but lower quality)
# SEM_CACHE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# SEM_CACHE_EMBED_MODEL_PATH=/path/to/all-MiniLM-L6-v2
# SEM_CACHE_VECTOR_DIM=384

SEM_CACHE_MONGO_URI=mongodb://127.0.0.1:27017
SEM_CACHE_MONGO_DB=semcache
SEM_CACHE_MONGO_COLLECTION=semantic_entries
SEM_CACHE_MONGO_CONNECT_TIMEOUT_MS=3000

SEM_CACHE_TOP_K=5
SEM_CACHE_NORMALIZE=1

SEM_CACHE_MILVUS_URI=http://127.0.0.1:19530
SEM_CACHE_MILVUS_USER=root
SEM_CACHE_MILVUS_PASSWORD=Milvus
SEM_CACHE_MILVUS_SECURE=0
SEM_CACHE_MILVUS_COLLECTION=semcache_direct_v2

SEM_CACHE_ALLOW_WITH_RAG=1

# -----------------------------------------------------------------------------
# RAG
# -----------------------------------------------------------------------------
RAG_ENABLED=1
RAG_BACKEND=milvus
RAG_TOP_K=4
RAG_MAX_CONTEXT_CHARS=4000
RAG_SCORE_MODE=similarity
RAG_SCORE_THRESHOLD=0.60

RAG_STORE_ROOT_DIR=/home/mohamad/LLM-end-to-end-Service-main/rag_store_tenants
RAG_MANIFEST_ROOT_DIR=/home/mohamad/LLM-end-to-end-Service-main/rag_store_tenants
RAG_FALLBACK_TENANT=
RAG_LOCAL_EMBED_MODEL_PATH=/path/to/bge-base-en-v1.5

BGE_MODEL_PATH=/home/mohamad/LLM-end-to-end-Service-main/bge-base-en-v1.5
BGE_DEVICE=cpu
BGE_DIM=768
BGE_NORMALIZE=1

MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=root:Milvus
MILVUS_COLLECTION=rag_chunks_seaweed_v2
MILVUS_VECTOR_FIELD=embedding
MILVUS_TENANT_FIELD=tenant_id
MILVUS_METRIC_TYPE=COSINE

# -----------------------------------------------------------------------------
# Object store for RAG chunks / PDFs
# -----------------------------------------------------------------------------
RAG_OBJECT_STORE_ENABLED=1
RAG_OBJECT_STORE_ENDPOINT_URL=http://127.0.0.1:8333
RAG_OBJECT_STORE_ACCESS_KEY_ID=llmbenchadmin
RAG_OBJECT_STORE_SECRET_ACCESS_KEY=llmbenchsecretkey123
RAG_OBJECT_STORE_BUCKET=llm-rag-store
RAG_OBJECT_STORE_REGION=us-east-1
RAG_OBJECT_STORE_USE_SSL=0
RAG_OBJECT_STORE_VERIFY=false
RAG_OBJECT_STORE_PREFIX=rag
RAG_OBJECT_STORE_LOCAL_CACHE_TTL_SEC=60

# -----------------------------------------------------------------------------
# Prompt / KB versioning
# -----------------------------------------------------------------------------
KB_VERSION=no-rag
SYSTEM_PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# Token counting
# -----------------------------------------------------------------------------
TOKENIZER_PATH=/home/mohamad/LLM-end-to-end-Service-main/Qwen2.5-0.5B-Instruct
TOKENIZER_LOCAL_ONLY=1

# -----------------------------------------------------------------------------
# Benchmark / routing behavior
# -----------------------------------------------------------------------------
BENCHMARK_SHADOW_MODE=0
RAG_RETRIEVE_EVERY_REQUEST=1
RETURN_DEBUG_BLOCKS=1

# -----------------------------------------------------------------------------
# Offline runtime
# -----------------------------------------------------------------------------
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# -----------------------------------------------------------------------------
# Auth / tenant selection
# -----------------------------------------------------------------------------
AUTH_ENABLED=0
DEV_TENANT_ID=tenantA
TENANT_CLAIM=tenant_id

KEYCLOAK_ISSUER=
KEYCLOAK_JWKS_URL=
KEYCLOAK_AUDIENCE=
JWKS_CACHE_TTL_SEC=300
