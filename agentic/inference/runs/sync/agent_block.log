               from sqlfluff.rules.L000 import L000                             
               from sqlfluff.core.parser import Segment                         
                                                                                
               class L031(L000):                                                
                   def _eval(self, segment):                                    
                       # Check if there is a join condition                     
                       if isinstance(segment.parent, Segment.JoinClause):       
                           return self._violate(segment, "Avoid using aliases in
